{
  "name": "@meirblachman/pr-review-needed",
  "version": "0.1.33",
  "description": "Generates a markdown summary of Azure DevOps PRs needing review",
  "type": "module",
  "bin": {
    "pr-review-needed": "dist/index.min.js"
  },
  "files": [
    "dist/index.min.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Meir017/ado-pr-review-needed.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "prepublishOnly": "npm run build && npm run bundle",
    "start": "tsx src/index.ts run",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "azure-devops-node-api": "^15.1.2",
    "commander": "^14.0.3",
    "picomatch": "^4.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
